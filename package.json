{
  "name": "ai-dev-runtime",
  "description": "AI-first CLI orchestration runtime for AI-assisted software development",
  "version": "0.1.0",
  "author": "Episkey",
  "bin": {
    "ai-dev": "./bin/run.js"
  },
  "dependencies": {
    "@oclif/core": "4.5.2",
    "@oclif/plugin-help": "^6"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/test": "^4",
    "@types/node": "^22",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "5.9.0-beta",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "keywords": [
    "oclif",
    "ai-dev",
    "orchestration"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "ai-dev",
    "dirname": "ai-dev",
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init"
    },
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
